{
  "name": "@lacausecrypto/air-quality",
  "private": true,
  "version": "0.1.0",
  "description": "MCP server exposing IRCELINE Belgian air quality public APIs",
  "type": "module",
  "license": "MIT",
  "bin": {
    "mcp-air-quality": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "default": "./dist/register.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'ok'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@lacausecrypto/core": "workspace:*",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/node": "^25.8.0",
    "@types/express": "^5.0.0",
    "vitest": "^3.1.0"
  }
}
