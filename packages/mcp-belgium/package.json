{
  "name": "mcp-belgium",
  "version": "0.1.0",
  "description": "Single aggregated MCP server exposing Belgian public data, transport, statistics, and geospatial domains",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lacausecrypto/mcp-belgium.git",
    "directory": "packages/mcp-belgium"
  },
  "homepage": "https://github.com/lacausecrypto/mcp-belgium#readme",
  "bugs": {
    "url": "https://github.com/lacausecrypto/mcp-belgium/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "belgium",
    "open-data",
    "transport",
    "geospatial",
    "statbel",
    "irail"
  ],
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "default": "./dist/register.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'ok'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.1.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@lacausecrypto/air-quality": "workspace:*",
    "@lacausecrypto/best-address": "workspace:*",
    "@lacausecrypto/core": "workspace:*",
    "@lacausecrypto/data-gov-be": "workspace:*",
    "@lacausecrypto/geoservices-wallonia": "workspace:*",
    "@lacausecrypto/infrabel": "workspace:*",
    "@lacausecrypto/irail": "workspace:*",
    "@lacausecrypto/kbo": "workspace:*",
    "@lacausecrypto/kmi": "workspace:*",
    "@lacausecrypto/mobility": "workspace:*",
    "@lacausecrypto/opendata-brussels": "workspace:*",
    "@lacausecrypto/opendata-flanders": "workspace:*",
    "@lacausecrypto/opendata-wallonia": "workspace:*",
    "@lacausecrypto/statbel": "workspace:*",
    "@lacausecrypto/stib": "workspace:*",
    "@lacausecrypto/urban-brussels": "workspace:*",
    "@lacausecrypto/urbis": "workspace:*",
    "@types/express": "^5.0.0",
    "@types/node": "^22.12.0",
    "tsup": "^8.5.0",
    "typescript": "^6.0.2",
    "vitest": "^3.1.0"
  }
}
