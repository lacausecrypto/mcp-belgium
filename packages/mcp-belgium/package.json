{
  "name": "@belgium-gov-mcp/belgium",
  "version": "0.1.0",
  "description": "Single aggregated MCP server exposing Belgian public data, transport, statistics, and geospatial domains",
  "type": "module",
  "license": "MIT",
  "bin": {
    "mcp-belgium": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./register": {
      "types": "./dist/register.d.ts",
      "default": "./dist/register.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:stdio": "MCP_TRANSPORT=stdio node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'ok'",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@belgium-gov-mcp/air-quality": "workspace:*",
    "@belgium-gov-mcp/best-address": "workspace:*",
    "@belgium-gov-mcp/core": "workspace:*",
    "@belgium-gov-mcp/data-gov-be": "workspace:*",
    "@belgium-gov-mcp/geoservices-wallonia": "workspace:*",
    "@belgium-gov-mcp/infrabel": "workspace:*",
    "@belgium-gov-mcp/irail": "workspace:*",
    "@belgium-gov-mcp/kbo": "workspace:*",
    "@belgium-gov-mcp/kmi": "workspace:*",
    "@belgium-gov-mcp/mobility": "workspace:*",
    "@belgium-gov-mcp/opendata-brussels": "workspace:*",
    "@belgium-gov-mcp/opendata-flanders": "workspace:*",
    "@belgium-gov-mcp/opendata-wallonia": "workspace:*",
    "@belgium-gov-mcp/statbel": "workspace:*",
    "@belgium-gov-mcp/stib": "workspace:*",
    "@belgium-gov-mcp/urban-brussels": "workspace:*",
    "@belgium-gov-mcp/urbis": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.12.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.0"
  }
}
